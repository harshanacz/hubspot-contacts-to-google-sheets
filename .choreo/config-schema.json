{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "wso2": {
      "type": "object",
      "properties": {
        "hubspot_contacts_to_google_sheet": {
          "type": "object",
          "properties": {
            "hubspotAccessToken": {
              "type": "string",
              "description": "HubSpot private app access token used to fetch contacts."
            },
            "googleClientId": {
              "type": "string",
              "description": "Google OAuth2 client ID used for Google Sheets access."
            },
            "googleClientSecret": {
              "type": "string",
              "description": "Google OAuth2 client secret."
            },
            "googleRefreshToken": {
              "type": "string",
              "description": "Refresh token used to obtain access tokens for Google Sheets API."
            },
            "googleRefreshUrl": {
              "type": "string",
              "description": ""
            },
            "spreadsheetId": {
              "type": "string",
              "description": "ID of the target Google Spreadsheet where contacts will be stored."
            },
            "sheetName": {
              "type": "string",
              "description": ""
            },
            "subscriberSheetName": {
              "type": "string",
              "description": ""
            },
            "leadSheetName": {
              "type": "string",
              "description": ""
            },
            "marketingqualifiedleadSheetName": {
              "type": "string",
              "description": ""
            },
            "salesqualifiedleadSheetName": {
              "type": "string",
              "description": ""
            },
            "opportunitySheetName": {
              "type": "string",
              "description": ""
            },
            "customerSheetName": {
              "type": "string",
              "description": ""
            },
            "evangelistSheetName": {
              "type": "string",
              "description": ""
            },
            "otherSheetName": {
              "type": "string",
              "description": ""
            },
            "defaultSheetName": {
              "type": "string",
              "description": ""
            },
            "fields": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": ""
            },
            "scheduleIntervalSeconds": {
              "type": "integer",
              "description": "Interval in seconds for periodic synchronization."
            },
            "lastSyncTimestamp": {
              "type": "string",
              "description": ""
            },
            "contactFilterProperty": {
              "type": "string",
              "description": "HubSpot contact property used for filtering contacts."
            },
            "contactFilterValue": {
              "type": "string",
              "description": "Value that must match the filter property for a contact to be synced."
            },
            "maxRows": {
              "type": "integer",
              "description": ""
            }
          },
          "additionalProperties": false,
          "required": [
            "hubspotAccessToken",
            "googleClientId",
            "googleClientSecret",
            "googleRefreshToken",
            "spreadsheetId",
            "sheetName"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
    "requiredLevel": 3
}
