# HubSpot API
hubspotAccessToken = "<your-hubspot-private-app-token>"

# Google OAuth2
googleClientId = "<your-google-client-id>"
googleClientSecret = "<your-google-client-secret>"
googleRefreshToken = "<your-google-refresh-token>"

# Google Spreadsheet target
spreadsheetId = "<your-google-spreadsheet-id>"
sheetName = "Sheet1"

# Lifecycle routing sheets
leadSheetName = "Leads"
customerSheetName = "Customers"
defaultSheetName = "Sheet1"

# Contact columns to export
fields = ["email", "firstname", "lastname", "phone"]

# Scheduler and limits
scheduleIntervalSeconds = 15
maxRows = 0

# Initial sync state (usually keep empty)
lastSyncTimestamp = ""

# Optional contact filter (leave empty to export all)
contactFilterProperty = ""
contactFilterValue = ""

# Example filter:
# contactFilterProperty = "lifecyclestage"
# contactFilterValue = "customer"
